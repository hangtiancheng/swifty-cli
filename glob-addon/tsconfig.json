{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"isolatedModules": true,
		"lib": [
			"es2022"
		],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "./dist",
		"rootDir": ".",
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "es2022",
		"types": [
			"node"
		],
		"verbatimModuleSyntax": true
	},
	"include": [
		"./glob.ts"
	]
}
