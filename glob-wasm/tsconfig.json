{
	"compilerOptions": {
		"rootDir": ".",
		"outDir": "./dist",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "es2022",
		"lib": ["es2022"],
		"types": ["node"],
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"strict": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"skipLibCheck": true
	},
	"include": ["index.ts"],
	"exclude": ["assembly", "build", "node_modules", "test"]
}
