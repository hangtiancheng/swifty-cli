# Swifty runtime artifacts (auto-generated, not committed)

# Local permission overrides — personal, not shared with team
.swifty/permissions.local.yaml

# Session transcripts & file history snapshots (per-session, runtime)
.swifty/sessions/
.swifty/file-history/

# Plan files (per-session, runtime)
.swifty/plans/

# Log files (per-session, runtime)
.swifty/logs/
.swifty/teams/*/logs/

# ── Committed (do NOT ignore) ──────────────────────────────────────────
# .swifty/config.yaml            — project config (shared)
# .swifty/permissions.yaml       — project permission rules (shared)
# .swifty/memory/                — project-level memories (shared, team)
# .swifty/skills/                — installed skills (shared)
# .swifty/agents/                — custom agent definitions (shared)
