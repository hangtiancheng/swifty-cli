{
  "name": "@swifty.js/swifty",
  "version": "0.0.1",
  "private": true,
  "description": "Swifty.js Swiftyy",
  "keywords": [
    "swifty.js",
    "swifty"
  ],
  "license": "ISC",
  "author": "https://github.com/hangtiancheng/swifty",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx ./src/main.tsx",
    "dev:docs": "vite",
    "build:docs": "vite build",
    "preview:docs": "vite preview",
    "lint": "eslint --fix ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt --write .",
    "git:commit": "git add -A && git commit -m \"feat: Introduce new features\"",
    "git:push": "pnpm git:commit && git push origin main"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@swifty.js/glob-addon": "workspace:*",
    "@swifty.js/glob-wasm": "workspace:*",
    "@swifty.js/marked-terminal": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.3.1",
    "chalk": "^5.6.2",
    "cli-cursor": "^5.0.0",
    "daisyui": "^5.5.23",
    "fuse.js": "^7.4.2",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.2.0",
    "lucide-static": "^1.21.0",
    "marked": "^18.0.5",
    "openai": "^6.44.0",
    "react": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-unicorn": "^65.0.1",
    "globals": "^17.6.0",
    "oxfmt": "^0.53.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.33.1"
}
