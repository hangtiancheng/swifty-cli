# SwiftyCode Environment Configuration
# Copy this file to .env and fill in your values.
# All variables are optional; defaults are used when unset.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: Override API base URL ---
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Daemon ---
# LARK_HOST=127.0.0.1
# LARK_PORT=7437

# --- Logging ---
# LARK_LOG_LEVEL=INFO
# LARK_LOG_FILE=~/.swifty/logs/core.log
# LARK_LOG_FORMAT=text

# --- Agent ---
# LARK_MAX_STEPS=20

# --- LLM ---
# LARK_LLM_DEFAULT_MODEL=claude-sonnet-4-6

# --- Tracing ---
# LARK_TRACE_ENABLED=true
# LARK_TRACE_FILE=~/.swifty/traces/daemon.jsonl
# LARK_TRACE_INCLUDE_LLM_PAYLOAD=true

# --- Permissions ---
# LARK_PERMISSION_TIMEOUT_S=60

# --- Compaction ---
# LARK_COMPACT_THRESHOLD=0.0
# LARK_COMPACT_TOOL_LIMIT=8000
# LARK_COMPACT_TOOL_KEEP=4000

# --- Config file override ---
# LARK_CONFIG=~/.swifty/config.toml
