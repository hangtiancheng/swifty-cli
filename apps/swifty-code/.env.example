# SwiftyCode Environment Configuration
# Copy this file to .env and fill in your values.
# All variables are optional; defaults are used when unset.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: Override API base URL ---
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Daemon ---
# SWIFTY_HOST=127.0.0.1
# SWIFTY_PORT=7437

# --- Logging ---
# SWIFTY_LOG_LEVEL=INFO
# SWIFTY_LOG_FILE=~/.swifty/logs/core.log
# SWIFTY_LOG_FORMAT=text

# --- Agent ---
# SWIFTY_MAX_STEPS=20

# --- LLM ---
# SWIFTY_LLM_DEFAULT_MODEL=claude-sonnet-4-6

# --- Tracing ---
# SWIFTY_TRACE_ENABLED=true
# SWIFTY_TRACE_FILE=~/.swifty/traces/daemon.jsonl
# SWIFTY_TRACE_INCLUDE_LLM_PAYLOAD=true

# --- Permissions ---
# SWIFTY_PERMISSION_TIMEOUT_S=60

# --- Compaction ---
# SWIFTY_COMPACT_THRESHOLD=0.0
# SWIFTY_COMPACT_TOOL_LIMIT=8000
# SWIFTY_COMPACT_TOOL_KEEP=4000

# --- Config file override ---
# SWIFTY_CONFIG=~/.swifty/config.toml
