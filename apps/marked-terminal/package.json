{
  "name": "@swifty.js/marked-terminal",
  "version": "0.0.1",
  "description": "forked marked terminal",
  "main": "./dist/index.cjs",
  "browser": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "node": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "default": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "marked",
    "terminal",
    "markdown"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.1",
  "peerDependencies": {
    "marked": ">17 <=18"
  },
  "dependencies": {
    "ansi-escapes": "^7.3.0",
    "ansi-regex": "^6.2.2",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "cli-table3": "^0.6.5",
    "node-emoji": "^2.2.0",
    "supports-hyperlinks": "^4.5.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.13.1",
    "marked": "^18.0.5",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
